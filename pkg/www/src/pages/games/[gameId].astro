---
import { Resource } from "sst"
import "@/styles/global.css"
import Header from "@/components/site/Header"
import { Button } from "@/components/ui/button"
import type { Game } from "@/lib/api-client"

const gameID = Number(Astro.params.gameId ?? "")

export const prerender = false

function formatPlayerName(game: Game, team: 1 | 2, slot: 1 | 2): string {
  const player =
    team === 1
      ? slot === 1
        ? game.team1Player1
        : game.team1Player2
      : slot === 1
        ? game.team2Player1
        : game.team2Player2

  if (player) {
    const fullName = [player.firstName, player.lastName].filter(Boolean).join(" ").trim()
    return fullName || player.username || `Player ${player.id}`
  }

  const id =
    team === 1
      ? slot === 1
        ? game.team1Player1Id
        : game.team1Player2Id
      : slot === 1
        ? game.team2Player1Id
        : game.team2Player2Id

  return `Player ${id}`
}

function formatDateTime(value: string | undefined): string {
  if (!value) {
    return "Unknown date"
  }

  const date = new Date(value)
  if (Number.isNaN(date.getTime())) {
    return "Unknown date"
  }

  return new Intl.DateTimeFormat(undefined, {
    dateStyle: "full",
    timeStyle: "short",
  }).format(date)
}

let game: Game | null = null
let errorMessage: string | null = null

if (!Number.isInteger(gameID) || gameID <= 0) {
  errorMessage = "Invalid game ID."
} else {
  try {
    const response = await fetch(`${Resource.API.url}/games/${gameID}`)
    if (!response.ok) {
      errorMessage = response.status === 404 ? "Game not found." : "Could not load this game."
    } else {
      game = (await response.json()) as Game
    }
  } catch {
    errorMessage = "Could not load this game."
  }
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Game Details | Padel Stats</title>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <Header client:load />
    <main class="mx-auto flex w-full max-w-6xl flex-1 px-4 py-10">
      {errorMessage || !game ? (
        <section class="w-full space-y-4 rounded-xl border border-border bg-card p-6 text-card-foreground shadow-sm">
          <p class="rounded-md border border-destructive/30 bg-destructive/10 px-3 py-2 text-sm text-destructive">
            {errorMessage ?? "Game not found."}
          </p>
          <Button asChild variant="outline" size="sm">
            <a href="/games">Back to games</a>
          </Button>
        </section>
      ) : (
        <section class="w-full space-y-6 rounded-xl border border-border bg-card p-6 text-card-foreground shadow-sm">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <h1 class="text-2xl font-semibold">Game #{game.id}</h1>
              <p class="text-sm text-muted-foreground">Played {formatDateTime(game.playedAt)}</p>
            </div>

            <Button asChild variant="outline" size="sm">
              <a href="/games">Back to games</a>
            </Button>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-lg border border-border bg-background p-4">
              <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Team 1</p>
              <p class="mt-2 text-base font-medium">{formatPlayerName(game, 1, 1)}</p>
              <p class="text-base font-medium">{formatPlayerName(game, 1, 2)}</p>
              <p class="mt-3 text-sm text-muted-foreground">
                Score: <span class="font-semibold text-foreground">{game.team1Score}</span>
              </p>
            </div>

            <div class="rounded-lg border border-border bg-background p-4">
              <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Team 2</p>
              <p class="mt-2 text-base font-medium">{formatPlayerName(game, 2, 1)}</p>
              <p class="text-base font-medium">{formatPlayerName(game, 2, 2)}</p>
              <p class="mt-3 text-sm text-muted-foreground">
                Score: <span class="font-semibold text-foreground">{game.team2Score}</span>
              </p>
            </div>
          </div>

          <div class="rounded-lg border border-border bg-background p-4 text-sm">
            <p>
              <span class="text-muted-foreground">Season ID:</span> {game.seasonId}
            </p>
            <p class="mt-1">
              <span class="text-muted-foreground">Created:</span> {formatDateTime(game.createdAt)}
            </p>
            <p class="mt-1">
              <span class="text-muted-foreground">Updated:</span> {formatDateTime(game.updatedAt)}
            </p>
          </div>
        </section>
      )}
    </main>
  </body>
</html>
